# ─── LLM / API Keys ──────────────────────────────────────────────────────────
# Get your free Gemini API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the model (default is gemini-2.5-flash which is free)
GEMINI_MODEL=gemini-2.5-flash

# Optional news/search API (leave empty to skip news retrieval)
# Recommended free option: https://newsapi.org (free 100 req/day)
NEWS_API_KEY=your_news_api_key_here

# ─── SEC EDGAR ───────────────────────────────────────────────────────────────
# No API key needed, but SEC requires a descriptive User-Agent header.
# Format: "YourName/1.0 contact@example.com"
SEC_USER_AGENT=Verity/1.0 [jaiswalanurag821@gmail.com]

# ─── App Config ──────────────────────────────────────────────────────────────
# Where to store ChromaDB vector data (relative path)
CHROMA_PERSIST_DIR=./chroma_db

# Where to store JSONL audit logs
AUDIT_LOG_DIR=./audit_logs

# Max retries for verifier loop (default 2)
VERIFIER_MAX_RETRIES=2

# API server config
API_HOST=0.0.0.0
API_PORT=8000

# ─── Rate Limiting ───────────────────────────────────────────────────────────
# SEC EDGAR fair-access: min seconds between requests (default 0.1)
EDGAR_REQUEST_DELAY=0.1
